{
  "id": "job_offer",
  "label": "Offre d'emploi",
  "repeatable": true,
  "status": true,
  "json": {
    "Main": {
      "uid": {
        "type": "UID",
        "config": {
          "label": "UID",
          "placeholder": "developpeur-nextjs"
        }
      },
      "title": {
        "type": "StructuredText",
        "config": {
          "label": "Titre",
          "placeholder": "Titre de l'offre",
          "single": "heading1"
        }
      },
      "date": {
        "type": "Date",
        "config": {
          "label": "Date de publication"
        }
      },
      "tags": {
        "type": "Group",
        "config": {
          "label": "Technologies",
          "fields": {
            "tag": {
              "type": "Text",
              "config": {
                "label": "Tag",
                "placeholder": "NextJS"
              }
            }
          }
        }
      },
      "description": {
        "type": "StructuredText",
        "config": {
          "label": "Description",
          "placeholder": "Description de l'offre...",
          "multi": "paragraph,strong,em,hyperlink,list-item,o-list-item"
        }
      }
    }
  }
}
